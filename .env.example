# ── Polymarket AI Trading System ──────────────────────────────
# Copy this file to .env and fill in your credentials

# Trading mode: true = paper trading, false = real trading
PAPER_TRADING=true

# ── Polymarket CLOB API credentials ──────────────────────────
# Your Ethereum private key (used to sign orders on Polygon)
POLYMARKET_PRIVATE_KEY=

# API credentials (created via ClobClient.create_or_derive_api_creds)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Optional: proxy/funder wallet address (leave empty if not using)
POLYMARKET_FUNDER=

# Chain ID: 137 = Polygon mainnet, 80002 = Amoy testnet
CHAIN_ID=137

# ── Safety limits (real trading only) ────────────────────────
MAX_DAILY_LOSS=100.0
